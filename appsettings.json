{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "ReverseProxy": {
    "ClusterLoadPolicy": "RoundRobin",
    "Routes": [
      {
        "RouteId": "route1",
        "ClusterId": "cluster1",
        "Match": {
          "Path": "{**catch-all}"
        }
      },
      {
        "RouteId": "route2",
        "ClusterId": "cluster2",
        "Match": {
          "Path": "{**catch-all}"
        }
      }
    ],
    "Clusters": [
      {
        "ClusterId": "cluster1",
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5001/" //Replace with the actual address of your backend service
          },
          "destination2": {
            "Address": "http://localhost:5002/" //Replace with the actual address of your backend service
          }
        }
      },
      {
        "ClusterId": "cluster2",
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5003/" //Replace with the actual address of your backend service
          },
          "destination2": {
            "Address": "http://localhost:5004/" //Replace with the actual address of your backend service
          }
        }
      }
    ]
  }
}
