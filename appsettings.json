{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.Routing": "Information",
      "Microsoft.ReverseProxy": "Information",
      "System": "Warning"
    },
    "Console": {
      "IncludeScopes": true,
      "TimestampFormat": "yyyy-MM-dd HH:mm:ss "
    },
    "File": {
      "Path": "logs/app-.log",
      "RollingInterval": "Day",
      "RetainedFileCountLimit": 7
    }
  },
  
  "AllowedHosts": "*",

  "RateLimiter": {
    "DefaultPolicy": {
      "PermitLimit": 200,
      "Window": "00:01:00",
      "QueueProcessingOrder": "OldestFirst",
      "QueueLimit": 20
    }
  },

  "Cors": {
    "AllowedOrigins": [
      "*"
    ]
  },

  "Jwt":{
    "key":"fb8e3580ad52fc115d61c079c02801dbd9bbc52681e022e301632c2adba68388",
    "Issuer":"MyApp",
    "Audience":"MyApp",
    "ExpiryInMinutes":60
  },

  "ReverseProxy": {
    "ClusterLoadPolicy": "RoundRobin",
    "Routes": [
      {
        "RouteId": "route1",
        "ClusterId": "cluster1",
        "Match": {
          "Path": "{**catch-all}"
        }
      },
      {
        "RouteId": "route2",
        "ClusterId": "cluster2",
        "Match": {
          "Path": "{**catch-all}"
        }
      }
    ],
    "Clusters": [
      {
        "ClusterId": "cluster1",
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5001/"
          },
          "destination2": {
            "Address": "http://localhost:5002/"
          }
        }
      },
      {
        "ClusterId": "cluster2",
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5003/"
          },
          "destination2": {
            "Address": "http://localhost:5004/"
          }
        }
      }
    ]
  }
}
